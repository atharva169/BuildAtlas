# BuildAtlas Frontend — Environment Variables
# Copy this file to .env and fill in your values

# API URL (leave empty to use Vite proxy → localhost:8000)
VITE_API_URL=

# Gemini API Key (for direct client-side calls, if enabled)
VITE_GEMINI_API_KEY=your_key_here

# Demo Mode — set to 'true' to run entirely from seed data (no API calls)
VITE_DEMO_MODE=true
